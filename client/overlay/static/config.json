{
  "_comment": "Standalone qwc2 deployment — no qwc-services backend. Only qgis-server at /ows is used. Service URLs are blanked so unused features fail closed instead of trying to call missing endpoints.",
  "searchServiceUrl": "",
  "searchDataServiceUrl": "",
  "editServiceUrl": "",
  "mapInfoService": "",
  "permalinkServiceUrl": "",
  "elevationServiceUrl": "",
  "featureReportService": "",
  "authServiceUrl": "",
  "routingServiceUrl": "",
  "availableLocales": {
    "en-US": "English"
  },
  "urlPositionFormat": "centerAndZoom",
  "urlPositionCrs": "EPSG:3857",
  "loadTranslationOverrides": false,
  "omitUrlParameterUpdates": false,
  "preserveExtentOnThemeSwitch": false,
  "preserveBackgroundOnThemeSwitch": true,
  "preserveNonThemeLayersOnThemeSwitch": false,
  "storeAllLayersInPermalink": false,
  "allowReorderingLayers": true,
  "preventSplittingGroupsWhenReordering": false,
  "allowLayerTreeSeparators": false,
  "flattenLayerTreeGroups": false,
  "allowRemovingThemeLayers": false,
  "globallyDisableDockableDialogs": false,
  "globallyDisableMaximizeableDialogs": false,
  "searchThemes": true,
  "searchThemeLayers": true,
  "allowAddingOtherThemes": false,
  "allowFractionalZoom": false,
  "localeAwareNumbers": false,
  "geodesicMeasurements": true,
  "trustWmsCapabilityURLs": false,
  "identifyTool": "Identify",
  "wmsDpi": 96,
  "wmsHidpi": false,
  "wmsMaxGetUrlLength": 2048,
  "qgisServerVersion": 3,
  "defaultColorScheme": "default",
  "defaultFeatureStyle": {
    "strokeColor": [0, 0, 255, 1],
    "strokeWidth": 1,
    "strokeDash": [4],
    "fillColor": [255, 0, 255, 0.33],
    "circleRadius": 10,
    "textFill": "black",
    "textStroke": "white",
    "textFont": "11pt sans-serif"
  },
  "projections": [
    {
      "code": "EPSG:2264",
      "proj": "+proj=lcc +lat_1=36.16666666666666 +lat_2=34.33333333333334 +lat_0=33.75 +lon_0=-79 +x_0=609601.2192024384 +y_0=0 +ellps=GRS80 +towgs84=0,0,0,0,0,0,0 +units=us-ft +no_defs",
      "label": "NAD83 / North Carolina (ftUS)"
    }
  ],
  "plugins": {
    "common": [
      { "name": "API" },
      { "name": "BackgroundSwitcher", "cfg": { "position": 0 } },
      { "name": "Bookmark" },
      { "name": "BottomBar" },
      { "name": "Help" },
      { "name": "HomeButton", "cfg": { "position": 6 } },
      { "name": "Identify", "cfg": { "params": { "FI_POINT_TOLERANCE": 8, "FI_LINE_TOLERANCE": 8, "FI_POLYGON_TOLERANCE": 4 } } },
      { "name": "LayerTree", "cfg": { "showLegendIcons": true, "showRootEntry": false, "showQueryableIcon": true, "allowImport": false, "allowMapTips": true, "allowCompare": false, "groupTogglesSublayers": true } },
      { "name": "LocateButton", "cfg": { "position": 2 } },
      { "name": "Map", "cfg": { "mapOptions": {} } },
      { "name": "MapCopyright" },
      { "name": "MapInfoTooltip" },
      { "name": "MapLegend" },
      { "name": "MapTip" },
      { "name": "Measure" },
      { "name": "OverviewMap" },
      { "name": "Print" },
      { "name": "ScratchDrawing" },
      { "name": "Settings" },
      { "name": "Share" },
      { "name": "StartupMarker" },
      { "name": "ThemeSwitcher" },
      { "name": "TopBar", "cfg": {
          "appMenuClearsTask": true,
          "menuItems": [
            { "key": "LayerTree", "icon": "layers" },
            { "key": "Print", "icon": "print" },
            { "key": "Bookmark", "icon": "bookmark" },
            { "key": "Share", "icon": "share" },
            { "key": "Help", "icon": "info" }
          ],
          "toolbarItems": [
            { "key": "Measure", "icon": "measure" },
            { "key": "Identify", "icon": "identify_region", "mode": "Region" }
          ]
        }
      }
    ],
    "mobile": [],
    "desktop": [
      { "name": "ZoomIn", "cfg": { "position": 4 } },
      { "name": "ZoomOut", "cfg": { "position": 5 } }
    ]
  }
}
